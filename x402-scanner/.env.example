# x402 Scanner — Seller Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env

# Seller private key (Arc Testnet) — used to settle payments on-chain
# The seller's address receives USDC from buyers via GatewayWallet
X402_SELLER_KEY=

# Custom price per scan in USDC (default: 0.01)
# X402_PRICE=0.01

# Server port (default: 8742)
# X402_PORT=8742
